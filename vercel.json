{
  "rewrites": [
    { "source": "/api/:path(*)", "destination": "/api/:path" },
    { "source": "/:path(*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret"
  }
}
